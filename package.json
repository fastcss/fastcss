{
  "name": "fastcss",
  "description": "A config-driven SASS/SCSS utility CSS framework. Generate responsive helper classes for colors, typography, flexbox, grid, spacing and shadows from a single config map.",
  "version": "0.3.2",
  "style": "dist/fastcss.css",
  "sass": "scss/fastcss.scss",
  "scripts": {
    "dev": "webpack",
    "prod": "webpack && cross-env NODE_ENV=production webpack",
    "watch": "webpack --progress --color --watch",
    "lint": "sass --verbose --no-source-map scss/build.scss > /dev/null"
  },
  "keywords": [
    "fastcss",
    "css",
    "sass",
    "scss",
    "utility",
    "framework",
    "utility-css",
    "responsive",
    "flexbox",
    "grid",
    "design-tokens",
    "css-framework",
    "sass-framework",
    "helper-classes"
  ],
  "author": "Lucian Ene <lucianene@mail.com>",
  "license": "MIT",
  "homepage": "http://fastcss.org",
  "repository": {
    "type": "git",
    "url": "git://github.com/fastcss/fastcss.git"
  },
  "bugs": {
    "url": "https://github.com/fastcss/fastcss/issues"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "ignore-emit-webpack-plugin": "^2.0.6",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.12",
    "postcss-loader": "^8.2.1",
    "postcss-sort-media-queries": "^6.5.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
